# Models — large binary weights, tracked via Git LFS or stored externally
# Keep the models/ folder structure but ignore downloaded/trained weights
models/xet
models/hub/
models/bert_tunning_model/
models/bert_tunning_model_*/

# Exception: BETO v2 is tracked via Git LFS (see .gitattributes) — best-performing
# model (macro F1 0.976), kept in the repo for reproducibility.
!models/bert_tunning_model_beto_v2/
!models/bert_tunning_model_beto_v2/**

# Exception: BETO v1 (8-class, no `otro`) is tracked via Git LFS (see .gitattributes) —
# kept alongside v2 for comparison/reproducibility.
!models/bert_tunning_model_beto/
!models/bert_tunning_model_beto/**

# ood_stats.npz is a locally-generated artifact (via train/compute-ood-stats), not part of
# the committed checkpoint. Re-ignore it inside the two exceptions above so it can't be
# silently deleted by git operations (e.g. git clean) that remove untracked files — it
# disappeared once already because it was un-ignored but never actually committed.
models/bert_tunning_model_beto_v2/**/ood_stats.npz
models/bert_tunning_model_beto/**/ood_stats.npz

