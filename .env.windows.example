# Windows parameter template — copy to .env and adjust to your machine.
# uv run copy: `copy .env.windows.example .env`

# Root folder with labeled PDF subfolders (see FOLDER_TO_LABEL in src/settings.py).
DOCS_ROOT=C:\Users\YourUser\Downloads\downloadsdocs\downloads

# Fine-tuned model output directory. Relative paths work on any OS.
OUTPUT_DIR=./models/bert_tunning_model

# Parquet dataset cache.
CACHE_PATH=./data/bert_tunning_cache.parquet
